{
    "name": "hadits-monorepo",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "dev:frontend": "npm run dev --workspace=frontend",
        "dev:backend": "npm run dev --workspace=backend",
        "build:frontend": "npm run build --workspace=frontend",
        "build:backend": "npm run build --workspace=backend",
        "build": "cd frontend && next build"
    },
    "dependencies": {
        "@sparticuz/chromium": "^127.0.0",
        "@sparticuz/chromium-min": "^127.0.0",
        "axios": "^1.7.7",
        "cheerio": "^1.0.0",
        "cors": "^2.8.5",
        "express": "^4.18.1",
        "dotenv": "^16.0.3",
        "next": "14.2.8",
        "react": "^18",
        "react-dom": "^18",
        "puppeteer": "^23.3.0",
        "puppeteer-core": "^23.3.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.12",
        "@types/express": "^4.17.17",
        "@types/node": "^20.0.0",
        "@vercel/node": "^3.2.12",
        "typescript": "^5.0.0"
    }
}